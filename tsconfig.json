{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "types": ["bun"],
    "paths": {
      "@/*": ["./src/*"],
      "drizzle/*": ["./drizzle/*"]
    }
  },
  "include": ["src/**/*", "drizzle/**/*.ts", "drizzle.config.ts", "env.d.ts"]
}
