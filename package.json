{
    "name": "deko-voice-bot",
    "version": "3.7.4",
    "type": "module",
    "private": true,
    "module": "src/main.ts",
    "license": "MIT",
    "packageManager": "pnpm@11.9.0",
    "engines": {
        "node": ">=22.0.0"
    },
    "imports": {
        "#root/*.js": "./src/*.ts",
        "#root/*": "./src/*.ts",
        "#drizzle/*.js": "./drizzle/*.ts",
        "#drizzle/*": "./drizzle/*.ts"
    },
    "scripts": {
        "dev": "NODE_ENV=development node --watch ./src/main.ts",
        "build": "tsdown",
        "start": "NODE_ENV=production node ./dist/main.mjs",
        "typecheck": "tsc",
        "lint": "biome check",
        "lint:write": "biome check --write",
        "format": "biome format --write .",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "node ./drizzle/migrate.ts"
    },
    "dependencies": {
        "@grammyjs/auto-chat-action": "0.1.1",
        "@grammyjs/commands": "1.3.2",
        "@grammyjs/conversations": "2.1.1",
        "@grammyjs/hydrate": "1.7.0",
        "@grammyjs/i18n": "1.1.2",
        "@grammyjs/menu": "1.3.1",
        "@grammyjs/parse-mode": "1.11.1",
        "@grammyjs/runner": "2.0.3",
        "@hono/node-server": "2.0.6",
        "callback-data": "1.1.1",
        "drizzle-orm": "0.45.2",
        "grammy": "1.44.0",
        "hono": "4.12.27",
        "pino": "10.3.1",
        "pino-pretty": "13.1.3",
        "postgres": "3.4.9",
        "valibot": "1.4.1"
    },
    "devDependencies": {
        "@biomejs/biome": "2.5.1",
        "@types/node": "26.0.0",
        "drizzle-kit": "0.31.10",
        "tsdown": "0.22.3",
        "typescript": "6.0.3"
    }
}
