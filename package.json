{
    "name": "deko-voice-bot",
    "version": "3.7.0",
    "type": "module",
    "module": "src/main.ts",
    "scripts": {
        "dev": "NODE_ENV=development bun run --watch ./src/main.ts",
        "start": "NODE_ENV=production bun run ./src/main.ts",
        "lint": "biome check",
        "lint:write": "biome check --write",
        "format": "biome format --write .",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "bun run drizzle/migrate.ts"
    },
    "dependencies": {
        "@grammyjs/auto-chat-action": "0.1.1",
        "@grammyjs/commands": "1.3.2",
        "@grammyjs/conversations": "2.1.1",
        "@grammyjs/hydrate": "1.6.0",
        "@grammyjs/i18n": "1.1.2",
        "@grammyjs/menu": "1.3.1",
        "@grammyjs/parse-mode": "1.11.1",
        "@grammyjs/runner": "2.0.3",
        "callback-data": "1.1.1",
        "dayjs": "1.11.20",
        "drizzle-orm": "0.45.2",
        "grammy": "1.42.0",
        "hono": "4.12.14",
        "pino": "10.3.1",
        "pino-pretty": "13.1.3",
        "postgres": "3.4.9",
        "valibot": "1.3.1"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.12",
        "@types/bun": "1.3.12",
        "drizzle-kit": "0.31.10",
        "typescript": "6.0.3"
    }
}
