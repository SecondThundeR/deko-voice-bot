{
  "name": "deko-voice-bot",
  "version": "3.6.0",
  "type": "module",
  "module": "bot.ts",
  "scripts": {
    "start": "NODE_ENV=production bun run --smol bot.ts",
    "dev": "DEBUG=grammy* NODE_ENV=development bun --watch run bot.ts",
    "format:check": "prettier . --check",
    "format:fix": "prettier . --write",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run drizzle/migrate.ts"
  },
  "dependencies": {
    "@grammyjs/auto-retry": "^2.0.2",
    "@grammyjs/conversations": "^2.1.1",
    "@grammyjs/i18n": "^1.1.2",
    "@grammyjs/menu": "^1.3.1",
    "@grammyjs/runner": "^2.0.3",
    "dayjs": "^1.11.20",
    "drizzle-orm": "^0.45.2",
    "grammy": "^1.42.0",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2"
  }
}
